{
  "name": "camera-perf",
  "version": "0.1.0",
  "description": "AI-powered Camera performance analysis — specialized trace analysis for Android Camera preview, recording, and multi-output scenarios",
  "private": true,
  "scripts": {
    "dev": "./scripts/start-dev.sh",
    "dev:backend": "cd backend && npm run dev",
    "build": "cd backend && npm run build",
    "start": "cd backend && npm start",
    "quality": "npm run lint",
    "verify:pr": "npm --prefix backend run verify:pr"
  },
  "engines": {
    "node": ">=24.0.0 <25.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "knip": "^6.9.0"
  }
}
