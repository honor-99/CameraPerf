# ===================================================
# CameraPerf Configuration
# ===================================================
# Copy this file:
#   Local source: cp backend/.env.example backend/.env
#   Docker:        cp backend/.env.example .env
#
# CameraPerf uses the Claude Agent SDK as its AI runtime.
# Connect via Anthropic API directly or via a proxy.

# ===================================================
# Option 1: Anthropic Direct (recommended)
# ===================================================
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ===================================================
# Option 2: Third-party LLM via API Proxy
# ===================================================
# Requires a proxy (one-api / new-api / LiteLLM) converting
# Anthropic Messages API -> provider's OpenAI-compatible API.
# ANTHROPIC_BASE_URL=http://localhost:3000
# ANTHROPIC_API_KEY=sk-proxy-xxx

# --- DeepSeek ---
# CLAUDE_MODEL=deepseek-v4-pro
# CLAUDE_LIGHT_MODEL=deepseek-v4-flash

# --- GLM / ZhipuAI ---
# CLAUDE_MODEL=glm-5.1
# CLAUDE_LIGHT_MODEL=glm-4.7-flash

# ===================================================
# Model Tuning (optional)
# ===================================================
# CLAUDE_MAX_TURNS=40
# CLAUDE_QUICK_MAX_TURNS=8
# CAMERAPERF_OUTPUT_LANGUAGE=zh-CN

# ===================================================
# Server
# ===================================================
PORT=3000
NODE_ENV=development

# ===================================================
# Trace Processor (auto-detected if not set)
# ===================================================
# TRACE_PROCESSOR_PATH=/path/to/trace_processor_shell

# ===================================================
# File Upload
# ===================================================
MAX_FILE_SIZE=2147483648
UPLOAD_DIR=./uploads
