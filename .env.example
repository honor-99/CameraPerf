# Server Configuration
PORT=3000
NODE_ENV=development

# API Authentication (recommended in any shared environment)
# CAMERAPERF_API_KEY=replace_with_a_strong_random_secret

# AI Service Configuration
# Default runtime is agentv3 (Claude Agent SDK) when AI_SERVICE is unset.

# Claude Configuration
# ANTHROPIC_API_KEY=your_claude_api_key_here
# CLAUDE_MODEL=claude-sonnet-4-6

# DeepSeek Configuration (for cost-effective trace analysis)
# DEEPSEEK_API_KEY=your_deepseek_api_key_here
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# File Upload (Max file size for trace uploads: 2GB)
MAX_FILE_SIZE=2147483648
UPLOAD_DIR=./uploads

# Perfetto Configuration (optional - uses default paths if not set)
# TRACE_PROCESSOR_PATH=/path/to/trace_processor_shell

# CORS
FRONTEND_URL=http://localhost:3000

# Agent feature flags
FEATURE_AGENT_SCENE_RECONSTRUCT=true
FEATURE_AGENT_LOGS_API=true
